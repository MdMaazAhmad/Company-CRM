generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─────────────────────────────────────────────────────────
// TENANT
// ─────────────────────────────────────────────────────────

model Organization {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique // company name → subdomain/URL
  plan            String    @default("FREE") // SaaS billing tier: FREE | PRO | BUSINESS
  active          Boolean   @default(true)
  invoiceSeq      Int       @default(0) // running counter for invoice numbers (per org)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  billingAddress  String?
  billingPhone    String?
  status          String    @default("ACTIVE")
  subscribedUntil DateTime?
  blockedReason   String?
  billingEmail    String?
  billingWebsite  String?
  gstin           String?
  placeOfSupply   String?
  defaultHsnSac   String?
  gstRate         Float     @default(18)
  monthlyFee      Int?

  users             User[]
  contacts          Contact[]
  projects          Project[]
  payments          Payment[]
  invoices          Invoice[]
  followUps         FollowUp[]
  interactions      Interaction[]
  plans             Plan[]
  sources           Source[]
  tasks             Task[]
  activities        TaskActivity[]
  comments          TaskComment[]
  timeLogs          TimeLog[]
  categories        Category[]
  loginSessions     LoginSession[]
  platformPayments  PlatformPayment[]
  platformAuditLogs PlatformAuditLog[]
  leadActivities    LeadActivity[]
  meetings          Meeting[]
  meetingNotes      MeetingNote[]
}

// ─────────────────────────────────────────────────────────
// CRM
// ─────────────────────────────────────────────────────────

model Contact {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name           String
  business       String?
  phone          String?
  whatsapp       String?
  email          String?
  city           String?
  source         String?
  notes          String?
  gstin          String?
  billingAddress String?
  state          String?
  stage          String    @default("LEAD")
  status         String    @default("NEW")
  plan           String?
  quotedPrice    Int?
  dropReason     String?
  convertedAt    DateTime?

  assigneeId     String?
  assignee       User?     @relation("ContactAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  nextActionAt   DateTime?
  nextActionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects       Project[]
  followUps      FollowUp[]
  interactions   Interaction[]
  leadActivities LeadActivity[]
  meetings       Meeting[]

  @@index([orgId])
  @@index([assigneeId])
  @@index([nextActionAt])
}

model LeadActivity {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String

  type       String    @default("FOLLOW_UP")
  // CALL | WHATSAPP | EMAIL | MEETING | QUOTE | FOLLOW_UP | NOTE
  title      String?
  dueDate    DateTime?
  done       Boolean   @default(false)
  outcome    String?
  assigneeId String?
  assignee   User?     @relation("LeadActivityAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([contactId])
  @@index([assigneeId])
  @@index([dueDate])
}

model Project {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  name      String
  status    String    @default("NOT_STARTED")
  // NOT_STARTED | IN_PROGRESS | REVIEW | LIVE | ON_HOLD
  price     Int?
  dueDate   DateTime?
  liveUrl   String?
  notes     String?
  gstRate   Float?
  hsnSac    String?
  taxMode   String    @default("INTRA")

  // ── billing ──
  billingType   String    @default("ONE_TIME") // ONE_TIME | MONTHLY
  monthlyAmount Int? // recurring charge per month (MONTHLY only)
  splitBilling  Boolean   @default(false) // false = full on 1st; true = 50/50 on 1st & 15th
  billingActive Boolean   @default(true) // pause/stop recurring generation
  billingStart  DateTime? // first cycle date (defaults to project creation month)
  billingDay    Int       @default(1) // anchor day for the "full"/"first-half" invoice

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]
  invoices Invoice[]
  tasks    Task[]
  meetings Meeting[]

  @@index([orgId])
  @@index([contactId])
}

model Invoice {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  cgstRate    Float    @default(9)
  sgstRate    Float    @default(9)
  hsnSac      String?
  clientGstin String?
  gstRate     Float    @default(18)
  taxMode     String   @default("INTRA")
  number      String // INV-2026-0001 (unique per org)
  amount      Int
  dueDate     DateTime
  periodLabel String // "June 2026" or "June 2026 (1st half)"
  // Idempotency key so re-running generation never double-creates the same cycle.
  // e.g. "2026-06-FULL" or "2026-06-H1" / "2026-06-H2"
  periodKey   String
  status      String   @default("UNPAID") // UNPAID | PARTIAL | PAID | VOID
  issuedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments Payment[]

  @@unique([projectId, periodKey]) // one invoice per project per cycle — enforces idempotency
  @@index([orgId])
  @@index([projectId])
  @@index([status])
}

model Payment {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  // Optional: a payment may settle a specific invoice (MONTHLY billing).
  // Null for one-time project payments — keeps the existing flow unchanged.
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  invoiceId String?

  amount    Int
  kind      String   @default("PARTIAL") // ADVANCE | PARTIAL | MILESTONE | FINAL
  method    String? // cash | upi | bank | card
  note      String?
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([projectId])
  @@index([invoiceId])
}

model FollowUp {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  dueDate   DateTime
  done      Boolean  @default(false)
  note      String?
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([contactId])
}

model Interaction {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  channel   String // call | whatsapp | email | meeting
  summary   String
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([contactId])
}

model Category {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  label     String
  color     String   @default("#94A3B8")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([orgId])
}

model LoginSession {
  id       String       @id @default(cuid())
  orgId    String
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  loginAt  DateTime     @default(now())
  logoutAt DateTime?

  @@index([orgId])
  @@index([userId])
}

model Plan {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name         String
  category     String // WordPress | Shopify | Custom | Marketing | Video | Performance
  sellPrice    Int
  gstRate      Float?
  hsnSac       String?
  breakPrice   Int?
  regularPrice Int? // struck-through "regular" price shown to client
  delivery     String?
  active       Boolean @default(true)
  sortOrder    Int     @default(0)

  // ── billing ──
  billingType  String @default("ONE_TIME") // ONE_TIME | MONTHLY
  monthlyPrice Int? // recurring price (MONTHLY plans)

  // detail-page fields
  tagline   String? // one-line pitch
  features  String? // JSON array of feature strings
  costMin   Int? // your hard cost (low)
  costMax   Int? // your hard cost (high)
  target    String? // who this plan is for
  pitch     String? // opening line / script
  objection String? // key objection + answer
  upsell    String? // upsell note

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model Source {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  label     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([orgId])
}

// ─────────────────────────────────────────────────────────
// TEAM / AUTH
// ─────────────────────────────────────────────────────────

model User {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name         String
  email        String
  passwordHash String
  role         String   @default("MEMBER") // OWNER | ADMIN | MEMBER | VIEWER (within an org)
  isSuperAdmin Boolean  @default(false) // YOU — cross-org support/admin
  active       Boolean  @default(true)
  avatarColor  String   @default("#FF6B00")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  team         String   @default("BOTH") // SALES | DELIVERY | BOTH

  // NextAuth adapter
  accounts Account[]
  sessions Session[]

  // Task relations
  assignedTasks    Task[]         @relation("TaskAssignee")
  reportedTasks    Task[]         @relation("TaskReporter")
  activities       TaskActivity[]
  assignedContacts Contact[]      @relation("ContactAssignee")
  comments         TaskComment[]
  timeLogs         TimeLog[]
  loginSessions    LoginSession[]
  leadActivities   LeadActivity[] @relation("LeadActivityAssignee")
  hostedMeetings   Meeting[]      @relation("MeetingHost")
  meetingNotes     MeetingNote[]  @relation("MeetingNoteAuthor")

  @@unique([orgId, email]) // email unique per company, not globally
  @@index([orgId])
}

// NextAuth (Auth.js) Prisma adapter models — field names required verbatim
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Meeting {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String

  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId     String?
  summary       String?
  transcriptUrl String?
  externalId    String?
  hostId        String?
  host          User?    @relation("MeetingHost", fields: [hostId], references: [id], onDelete: SetNull)

  title    String
  startAt  DateTime
  endAt    DateTime?
  location String?
  link     String?
  status   String    @default("SCHEDULED")
  outcome  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes MeetingNote[]

  @@index([orgId])
  @@index([contactId])
  @@index([startAt])
}

model MeetingNote {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  author    User?    @relation("MeetingNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  authorId  String?
  body      String
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([meetingId])
}

// ─────────────────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────────────────

model Task {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  title         String
  description   String?
  status        String    @default("BACKLOG") // BACKLOG | TODO | IN_PROGRESS | IN_REVIEW | DONE | BLOCKED
  priority      String    @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  assigneeId    String?
  reporterId    String
  dueDate       DateTime?
  estimateHours Int?
  startedAt     DateTime? // when work clock started (e.g. 3pm)
  completedAt   DateTime? // when actually finished (e.g. 5pm)
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignee   User?          @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter   User           @relation("TaskReporter", fields: [reporterId], references: [id])
  activities TaskActivity[]
  comments   TaskComment[]
  timeLogs   TimeLog[]

  @@index([orgId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

model TaskActivity {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  type      String // CREATED | STATUS_CHANGED | ASSIGNED | PRIORITY_CHANGED | COMMENTED | LOGGED_TIME | DUE_CHANGED | TITLE_CHANGED
  fromValue String?
  toValue   String?
  note      String?
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([taskId])
}

model TaskComment {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([taskId])
}

model TimeLog {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  hours     Float
  note      String?
  spentOn   DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([taskId])
}

// ─────────────────────────────────────────────────────────
// PLATFORM (super-admin billing control plane)
// ─────────────────────────────────────────────────────────

model PlatformPlan {
  id           String   @id @default(cuid())
  name         String   @unique
  monthlyPrice Int      @default(0)
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
}

model PlatformPayment {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  amount    Int
  period    String?
  note      String?
  paidAt    DateTime     @default(now())
  createdAt DateTime     @default(now())

  @@index([orgId])
}

model PlatformAuditLog {
  id         String        @id @default(cuid())
  orgId      String?
  org        Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  actorId    String
  actorEmail String
  action     String
  detail     String?
  createdAt  DateTime      @default(now())

  @@index([orgId])
  @@index([createdAt])
}
