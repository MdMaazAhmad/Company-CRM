generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─────────────────────────────────────────────────────────
// TENANT
// ─────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // company name → subdomain/URL
  plan      String   @default("FREE") // SaaS billing tier: FREE | PRO | BUSINESS
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  contacts     Contact[]
  projects     Project[]
  payments     Payment[]
  followUps    FollowUp[]
  interactions Interaction[]
  plans        Plan[]
  sources      Source[]
  tasks        Task[]
  activities   TaskActivity[]
  comments     TaskComment[]
  timeLogs     TimeLog[]
}

// ─────────────────────────────────────────────────────────
// CRM
// ─────────────────────────────────────────────────────────

model Contact {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // identity
  name        String
  business    String?
  phone       String?
  whatsapp    String?
  email       String?
  city        String?
  source      String?  // referral | instagram | ad | walk-in
  notes       String?
  // pipeline — one record moves from LEAD to CLIENT
  stage       String   @default("LEAD")   // LEAD | CLIENT
  status      String   @default("NEW")
  // NEW | CONTACTED | FOLLOW_UP | QUOTED | NEGOTIATING | CONVERTED | DROPPED
  plan        String?
  quotedPrice Int?
  dropReason  String?
  convertedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects     Project[]
  followUps    FollowUp[]
  interactions Interaction[]

  @@index([orgId])
}

model Project {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  name      String
  status    String  @default("NOT_STARTED")
  // NOT_STARTED | IN_PROGRESS | REVIEW | LIVE | ON_HOLD
  price     Int?
  dueDate   DateTime?
  liveUrl   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]
  tasks    Task[]

  @@index([orgId])
  @@index([contactId])
}

model Payment {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  amount    Int
  kind      String   @default("PARTIAL") // ADVANCE | PARTIAL | MILESTONE | FINAL
  method    String?  // cash | upi | bank | card
  note      String?
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([projectId])
}

model FollowUp {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  dueDate   DateTime
  done      Boolean  @default(false)
  note      String?
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([contactId])
}

model Interaction {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  channel   String  // call | whatsapp | email | meeting
  summary   String
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([contactId])
}

model Plan {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name         String
  category     String   // WordPress | Shopify | Custom
  sellPrice    Int
  breakPrice   Int?
  regularPrice Int?     // struck-through "regular" price shown to client
  delivery     String?
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)

  // detail-page fields
  tagline   String?  // one-line pitch
  features  String?  // JSON array of feature strings
  costMin   Int?     // your hard cost (low)
  costMax   Int?     // your hard cost (high)
  target    String?  // who this plan is for
  pitch     String?  // opening line / script
  objection String?  // key objection + answer
  upsell    String?  // upsell note

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model Source {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  label     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([orgId])
}

// ─────────────────────────────────────────────────────────
// TEAM / AUTH
// ─────────────────────────────────────────────────────────

model User {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name         String
  email        String
  passwordHash String
  role         String   @default("MEMBER") // OWNER | ADMIN | MEMBER | VIEWER (within an org)
  isSuperAdmin Boolean  @default(false)    // YOU — cross-org support/admin
  active       Boolean  @default(true)
  avatarColor  String   @default("#FF6B00")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // NextAuth adapter
  accounts Account[]
  sessions Session[]

  // Task relations
  assignedTasks Task[]         @relation("TaskAssignee")
  reportedTasks Task[]         @relation("TaskReporter")
  activities    TaskActivity[]
  comments      TaskComment[]
  timeLogs      TimeLog[]

  @@unique([orgId, email]) // email unique per company, not globally
  @@index([orgId])
}

// NextAuth (Auth.js) Prisma adapter models — field names required verbatim
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────────────────

model Task {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  title         String
  description   String?
  status        String   @default("BACKLOG") // BACKLOG | TODO | IN_PROGRESS | IN_REVIEW | DONE | BLOCKED
  priority      String   @default("MEDIUM")  // LOW | MEDIUM | HIGH | URGENT
  assigneeId    String?
  reporterId    String
  dueDate       DateTime?
  estimateHours Int?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignee   User?          @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter   User           @relation("TaskReporter", fields: [reporterId], references: [id])
  activities TaskActivity[]
  comments   TaskComment[]
  timeLogs   TimeLog[]

  @@index([orgId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

model TaskActivity {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  user   User   @relation(fields: [userId], references: [id])
  userId String
  type      String // CREATED | STATUS_CHANGED | ASSIGNED | PRIORITY_CHANGED | COMMENTED | LOGGED_TIME | DUE_CHANGED | TITLE_CHANGED
  fromValue String?
  toValue   String?
  note      String?
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([taskId])
}

model TaskComment {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  user   User   @relation(fields: [userId], references: [id])
  userId String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([taskId])
}

model TimeLog {
  id    String @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  task    Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId  String
  user    User     @relation(fields: [userId], references: [id])
  userId  String
  hours   Float
  note    String?
  spentOn DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([taskId])
}